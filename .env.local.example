# Supabase - copy to .env.local and fill in your values
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin operations (invite users, etc.). Keep secret. From Dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# For invites: app URL for auth callback (e.g. https://your-domain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 1 to show debug line in portal header (email, role, tenant, portal)
# NEXT_PUBLIC_DEBUG_PORTAL_GATE=1

# For password reset: add these to Supabase Dashboard → Auth → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback

# OpenAI - for AI search over documents (embeddings + chat)
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# FlightAware AeroAPI - for Weather Brief filed route lookup (optional)
# Get from: flightaware.com/commercial/aeroapi
# FLIGHTAWARE_API_KEY=

# Stripe - Founding Pilot / Pro (annual only)
# Get from: Stripe Dashboard → Products → CrewRules Pro → Price (annual)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Super Admin revenue & fee estimates (USD list amounts; match Stripe price unit amounts)
# STRIPE_PRO_MONTHLY_PRICE_USD=
# STRIPE_PRO_ANNUAL_PRICE_USD=
# STRIPE_FOUNDING_PILOT_ANNUAL_PRICE_USD=
